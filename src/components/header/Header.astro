---
import ThemeIcon from "@components/ThemeIcon.astro";
import NavMenu from "./NavMenu.astro";
import menuData from "./menuData.json"
---

<header class="header flex items-center justify-between w-full py-4 px-20 bg-gray-50 dark:bg-gray-600">
    <p class="header-logo font-bold text-xl text-gray-900 dark:text-gray-50">Saul Hernandez Lara</p>
    <div class="header-container flex gap-5 items-center">
        <NavMenu menuData={menuData}/>
        <ThemeIcon/>
    </div>
</header>
