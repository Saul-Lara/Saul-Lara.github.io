---

---

<button id="theme-button" class="cursor-pointer group w-6 h-6">    
    <iconify-icon id="icon-theme" class="group-hover:scale-[.9] text-gray-600 dark:text-gray-50" icon="ph:sun-duotone" width="24" height="24"></iconify-icon>
</button>

<script is:inline>
    const iconTheme = document.getElementById("icon-theme")
    const theme = (() => {
        const localStorageTheme = localStorage?.getItem("theme") ?? '';

        if(["dark", "light"].includes(localStorageTheme)){
            return localStorageTheme;
        }

        if(window.matchMedia("(prefers-color-scheme:dark)").matches){
            return "dark";
        }else{
            return "light";
        }
    })()

    if(theme === "light"){
        document.documentElement.classList.remove("dark");
        iconTheme.setAttribute("icon", "ph:sun-duotone");
    }else{
        document.documentElement.classList.add("dark");
        iconTheme.setAttribute("icon", "iconamoon:mode-dark-duotone");
    }

    window.localStorage.setItem("theme", theme);

    const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage?.setItem("theme", isDark ? "dark" : "light");
        iconTheme.setAttribute("icon", isDark ? "iconamoon:mode-dark-duotone" : "ph:sun-duotone");
    }

    document.getElementById("theme-button")?.addEventListener("click", handleToggleClick);
</script>