import Header from "../components/header/Header.astro";

const { title, description } = Astro.props;
---

<html lang="en">
    <head>
        <BaseAstro {title} {description} />
    </head>
    <body>
        <Header />
        <main class="w-full">
            <slot />
        </main>
    </body>
</html>
